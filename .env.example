# ─── REQUIRED ─────────────────────────────────────────────
# Housecall Pro API Key (Settings > API in HCP dashboard)
HCP_API_KEY=your_housecall_pro_api_key_here

# Retell AI API Key (Retell dashboard > Settings)
RETELL_API_KEY=your_retell_api_key_here

# ─── DASHBOARD ────────────────────────────────────────────
# Password to protect /dashboard?key=… — change this in production
DASHBOARD_PASSWORD=change_me

# ─── OPTIONAL ─────────────────────────────────────────────
# Default employee ID jobs get assigned to (from HCP)
DEFAULT_EMPLOYEE_ID=

# Owner phone (E.164) — receives emergency transfer SMS / fallback calls
OWNER_PHONE=

# Railway sets PORT automatically — only override locally
PORT=8080
